     return await handleAnthropicCountTokensToGemini(req, res, { vendor: forcedVendor })
   }
 
+  // 🚫 Web 工具禁用策略：count_tokens 也需要移除 web 工具以保持一致
+  applyWebToolDisablePolicy(req.body)
+
   // 🔗 会话绑定验证（与 messages 端点保持一致）

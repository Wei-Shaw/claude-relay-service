   const sessionValidation = await claudeRelayConfigService.validateNewSession(
@@ -1907,3 +2072,11 @@ router.post('/api/event_logging/batch', (req, res) => {
 
 module.exports = router
 module.exports.handleMessagesRequest = handleMessagesRequest
+// 导出 web tool 策略函数（用于测试）
+module.exports._webToolPolicy = {
+  normalizeToolName,
+  isDisabledWebTool,
+  isDisabledWebToolChoice,
+  ensureWebToolDisabledNotice,
+  applyWebToolDisablePolicy
+}

# ============================================================================
# Claude Relay Service 生产环境配置
# ============================================================================
# 使用方法：复制此文件为 .env，然后修改下面的配置
# ============================================================================

# ============================================================================
# 🔐 安全配置（必填！）
# ============================================================================
# JWT 密钥：至少32字符的随机字符串
# 生成方法：openssl rand -hex 32
JWT_SECRET=请替换为你的JWT密钥至少32字符

# 加密密钥：32字符的加密密钥
# 生成方法：openssl rand -hex 16
ENCRYPTION_KEY=请替换为32字符加密密钥

# ============================================================================
# 👤 管理员配置（可选，不填则自动生成）
# ============================================================================
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your-secure-password

# ============================================================================
# 🌐 服务配置
# ============================================================================
# 注意：PORT 这里是 docker-compose.prod.yml 中宿主机外部映射端口（如 7250）
# 容器内部始终监听 3000，对应 docker-compose.prod.yml 中 "${PORT}:3000" 的冒号左边
PORT=7250
BIND_HOST=0.0.0.0

# ============================================================================
# 📊 Redis 配置
# ============================================================================
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# 🎯 Claude API 配置
# ============================================================================
CLAUDE_API_URL=https://api.anthropic.com/v1/messages
CLAUDE_API_VERSION=2023-06-01

# ============================================================================
# 📝 日志配置
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# 🔧 其他配置
# ============================================================================
TIMEZONE_OFFSET=8
DEBUG=false

# ============================================================================
# 🚀 Antigravity 配置
# ============================================================================
# Antigravity 上游端点（建议使用生产环境地址）
ANTIGRAVITY_API_URL=https://cloudcode-pa.googleapis.com
# Antigravity User-Agent（可选）
ANTIGRAVITY_USER_AGENT=antigravity/1.16.5 windows/amd64
# 是否允许在上游失败时自动切换到备用地址（推荐开启）
ANTIGRAVITY_API_URL_ALLOW_FALLBACK=true
# 每次请求最多尝试切换几次备用上游（默认2次）
ANTIGRAVITY_MAX_FALLBACKS_PER_REQUEST=2

# ============================================================================
# 🚫 错误处理配置
# ============================================================================
# 529错误处理：0表示禁用，>0表示过载状态持续时间（分钟）
CLAUDE_OVERLOAD_HANDLING_MINUTES=0
# 400错误处理：0表示禁用，>0表示临时禁用时间（分钟）
CLAUDE_CONSOLE_BLOCKED_HANDLING_MINUTES=10

# ============================================================================
# 🔗 会话管理配置
# ============================================================================
# 粘性会话TTL（小时），默认1小时
STICKY_SESSION_TTL_HOURS=1
# 续期阈值（分钟），默认15分钟
STICKY_SESSION_RENEWAL_THRESHOLD_MINUTES=15

# ============================================================================
# 🔧 Anthropic 调试与工具配置
# ============================================================================
# 工具失败时提示模型继续（仅 /antigravity/api 分流生效）
ANTHROPIC_TOOL_ERROR_CONTINUE=true
# 调试 Dump（生产环境建议关闭以节省磁盘）
ANTHROPIC_DEBUG_REQUEST_DUMP=false
ANTHROPIC_DEBUG_RESPONSE_DUMP=false
ANTHROPIC_DEBUG_TOOLS_DUMP=false
ANTIGRAVITY_DEBUG_UPSTREAM_REQUEST_DUMP=false
ANTIGRAVITY_DEBUG_UPSTREAM_RESPONSE_DUMP=false

# ============================================================================
# ⏱️ 请求超时配置
# ============================================================================
REQUEST_TIMEOUT=600000

# ============================================================================
# 🔌 Clash 智能代理管理器配置（可选）
# ============================================================================
# 使用 deploy/docker-compose.prod.yml 部署时，服务支持在检测到代理错误（502/503/504）
# 时自动触发节点测速并切换到最快节点。如不使用 Clash，所有变量保持默认即可。
#
# 配置步骤：
#   1. 复制 clash/config.yaml.example 为 clash/config.yaml 并填写节点信息
#   2. 以下变量与 clash/config.yaml 的设置保持一致

# Clash RESTful API 地址（Docker 内用容器名 clash，宿主机直连用 localhost）
CLASH_API_HOST=clash

# Clash RESTful API 端口（需与 clash/config.yaml 中 external-controller 端口一致）
CLASH_API_PORT=9090

# 要管理的代理组名称（需与 clash/config.yaml 中 proxy-groups 的 name 一致）
CLASH_PROXY_GROUP=自动选择

# 禁用自动切换（保留代理但不触发自动测速，调试时用）
# CLASH_AUTO_SWITCH=false

# 高级调整（一般保持默认即可）
# CLASH_COOLDOWN_MS=30000     # 切换冷却时间（毫秒）
# CLASH_DEBOUNCE_MS=3000      # 防抖等待时间（毫秒）
# CLASH_ERROR_THRESHOLD=2     # 触发切换的最小错误数
